{
  "description": "Example: fetch a 300px wide WebP preview of a product image from the Vendure Asset Server.",
  "request": {
    "method": "GET",
    "url": "http://localhost:3000/assets/source/91/demo-product.jpg?preset=thumb&w=300&format=webp"
