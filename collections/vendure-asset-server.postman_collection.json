      "id": "fabd4be7-9865-44c5-a96c-0c47f8454ccb",
      "name": "Retrieve Asset",
      "request": {
        "name": "Retrieve Asset",
        "description": {
          "content": "Serves the stored binary for the asset at `assetPath`. Supports\nimage transforms via query parameters when the asset is an image.\nResponses include `Content-Type`, `Content-Length`, `ETag`, and\ncache headers; ranged requests are supported for large files.\n",
          "type": "text/plain"
        },
        "url": {
          "path": [
            "assets",
            ":assetPath"
          ],
          "host": [
            "{{baseUrl}}"
          ],
          "query": [
            {
              "disabled": false,
              "key": "preset",
              "value": "<string>",
              "description": "Named preset configured on the AssetServerPlugin (`tiny`, `thumb`, `small`, `medium`, `large`, or custom)."
            },
            {
              "disabled": false,
              "key": "w",
              "value": "<integer>",
              "description": "Target width in pixels."
            },
            {
              "disabled": false,
              "key": "h",
              "value": "<integer>",
              "description": "Target height in pixels."
            },
            {
              "disabled": false,
              "key": "mode",
              "value": "<string>",
              "description": "Fit mode for resizing."
            },
            {
              "disabled": false,
              "key": "format",
              "value": "<string>",
              "description": "Output format override."
            },
            {
              "disabled": false,
              "key": "q",
              "value": "<integer>",
              "description": "Output quality (1-100) for lossy formats."
            }
          ],
          "variable": [
            {
              "disabled": false,
              "type": "any",
              "value": "<string>",
              "key": "assetPath",
              "description": "(Required) The stored asset path (filename and any storage prefix)."
            }
          ]
        },
        "header": [
          {
            "key": "Accept",
            "value": "image/jpeg"
          }
        ],
        "method": "GET",
        "auth": null
      },
